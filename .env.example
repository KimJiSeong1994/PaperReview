# Required
OPENAI_API_KEY=your-openai-api-key
JWT_SECRET=your-jwt-secret-min-32-chars

# Optional
S2_API_KEY=                # Semantic Scholar API key (relaxes citation tree rate limits)
GOOGLE_API_KEY=            # Google Gemini API key (poster generation)
CORS_ORIGINS=              # Allowed origins, comma-separated (default: *)
