# Required
OPENAI_API_KEY=your-openai-api-key
JWT_SECRET=your-jwt-secret-min-32-chars

# Environment: "production" enforces JWT_SECRET requirement, "development" allows random fallback
ENVIRONMENT=development

# Optional
DATA_DIR=data              # Base directory for data files (bookmarks, users, papers, workspace)
S2_API_KEY=                # Semantic Scholar API key (relaxes citation tree rate limits)
GOOGLE_API_KEY=            # Google Gemini API key (poster generation)
CORS_ORIGINS=              # Allowed origins, comma-separated (default: jiphyeonjeon.kr,localhost)
LEGACY_PASSWORD_SALT=      # First 16 chars of original JWT_SECRET (for legacy SHA-256 password migration)
