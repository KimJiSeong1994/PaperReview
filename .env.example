# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# Google API Key (optional, for Google Scholar enhanced search)
GOOGLE_API_KEY=

# API Authentication (optional, leave empty to disable)
API_AUTH_KEY=

# CORS Origins (comma-separated, default: * for development)
# Example for production: http://localhost:5173,https://yourdomain.com
CORS_ORIGINS=*
