{
  "id": "cs224n",
  "name": "CS224N: Natural Language Processing with Deep Learning",
  "university": "Stanford University",
  "instructor": "Christopher Manning",
  "difficulty": "advanced",
  "prerequisites": ["Calculus", "Linear Algebra", "CS109 (Probability)", "CS229 or CS230 (ML/Deep Learning)", "Python/PyTorch", "Linguistics basics (helpful)"],
  "description": "Deep learning approaches to NLP. Word vectors, neural networks, transformers, pretraining, and applications to machine translation, question answering, and text generation.",
