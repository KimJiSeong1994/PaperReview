  "modules": [
    {
      "id": "mod-01",
      "week": 1,
      "title": "Word Vectors and Word Senses",
      "description": "Distributed representations of words. From count-based to prediction-based word embeddings.",
      "topics": [
        {
          "id": "topic-01-01",
          "title": "Word2Vec",
          "papers": [
            {
              "id": "paper-cs224n-001",
              "title": "Efficient Estimation of Word Representations in Vector Space",
              "authors": ["Tomas Mikolov", "Kai Chen", "Greg Corrado", "Jeffrey Dean"],
              "year": 2013,
              "venue": "ICLR Workshop",
              "arxiv_id": "1301.3781",
              "doi": null,
              "category": "required",
              "context": "Word2Vec (CBOW, Skip-gram) 모델을 제안. 단어 임베딩 연구의 시작점이 되었다."
            },
            {
              "id": "paper-cs224n-002",
              "title": "Distributed Representations of Words and Phrases and their Compositionality",
              "authors": ["Tomas Mikolov", "Ilya Sutskever", "Kai Chen", "Greg Corrado", "Jeffrey Dean"],
              "year": 2013,
              "venue": "NeurIPS",
              "arxiv_id": "1310.4546",
              "doi": null,
              "category": "required",
              "context": "Skip-gram의 확장판. Negative sampling과 구절(phrase) 학습을 도입했다."
            }
          ]
        },
