{
  "id": "cs224w",
  "name": "CS224W: Machine Learning with Graphs",
  "university": "Stanford University",
  "instructor": "Jure Leskovec",
  "difficulty": "advanced",
  "prerequisites": ["CS109 (Probability)", "CS161 (Algorithms)", "CS229 or equivalent ML course", "Linear Algebra", "Graph Theory Basics", "Python/PyTorch"],
  "description": "Analysis of large-scale graph and network data. Graph neural networks, knowledge graphs, and applications to social networks, biology, and recommendation systems.",
  "url": "https://web.stanford.edu/class/cs224w/",
  "modules": [
    {
      "id": "mod-01",
      "week": 1,
      "title": "Introduction and Graph Structure",
      "description": "Fundamentals of graph theory and network properties. Why graphs are a powerful abstraction for relational data.",
      "topics": [
        {
          "id": "topic-01-01",
          "title": "Why Graphs?",
          "papers": [
            {
              "id": "paper-cs224w-001",
              "title": "The Graph Neural Network Model",
              "authors": ["Franco Scarselli", "Marco Gori", "Ah Chung Tsoi", "Markus Hagenbuchner", "Gabriele Monfardini"],
              "year": 2009,
              "venue": "IEEE Transactions on Neural Networks",
              "arxiv_id": null,
              "doi": "10.1109/TNN.2008.2005605",
              "category": "required",
              "context": "GNN 프레임워크를 최초로 제안한 기초 논문. 그래프 구조 데이터에 신경망을 적용하는 개념을 정립했다."
            },
            {
              "id": "paper-cs224w-002",
              "title": "Collective Classification in Network Data",
              "authors": ["Prithviraj Sen", "Galileo Namata", "Mustafa Bilgic", "Lise Getoor", "Brian Gallagher", "Tina Eliassi-Rad"],
              "year": 2008,
              "venue": "AI Magazine",
              "arxiv_id": null,
              "doi": "10.1609/aimag.v29i3.2157",
              "category": "optional",
              "context": "네트워크 데이터에서의 분류 문제를 체계적으로 정리한 서베이 논문."
            }
          ]
        },
        {
          "id": "topic-01-02",
          "title": "Properties of Networks",
          "papers": [
            {
