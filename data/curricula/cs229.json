          "papers": [
            {
              "id": "paper-cs229-011",
              "title": "Learning representations by back-propagating errors",
              "authors": ["David E. Rumelhart", "Geoffrey E. Hinton", "Ronald J. Williams"],
              "year": 1986,
              "venue": "Nature",
              "arxiv_id": null,
              "doi": "10.1038/323533a0",
              "category": "required",
              "context": "역전파 알고리즘을 실용화한 논문. 신경망 학습의 핵심 알고리즘을 확립했다."
            },
            {
              "id": "paper-cs229-012",
              "title": "Deep Learning",
              "authors": ["Yann LeCun", "Yoshua Bengio", "Geoffrey Hinton"],
              "year": 2015,
              "venue": "Nature",
              "arxiv_id": null,
              "doi": "10.1038/nature14539",
              "category": "required",
              "context": "딥러닝의 핵심 개념과 발전 역사를 정리한 3대 거장의 리뷰 논문."
            }
          ]
        },
        {
          "id": "topic-05-02",
          "title": "Modern Architectures",
          "papers": [
            {
              "id": "paper-cs229-013",
              "title": "Attention Is All You Need",
              "authors": ["Ashish Vaswani", "Noam Shazeer", "Niki Parmar", "Jakob Uszkoreit", "Llion Jones", "Aidan N. Gomez", "Łukasz Kaiser", "Illia Polosukhin"],
              "year": 2017,
              "venue": "NeurIPS",
              "arxiv_id": "1706.03762",
              "doi": null,
              "category": "required",
              "context": "Transformer: 어텐션 기반 아키텍처로 시퀀스 모델링을 혁신한 논문."
            }
          ]
        }
      ]
    },
    {
      "id": "mod-06",
      "week": 6,
      "title": "Reinforcement Learning",
