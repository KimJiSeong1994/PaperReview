{
  "id": "cs229",
  "name": "CS229: Machine Learning",
  "university": "Stanford University",
  "instructor": "Andrew Ng",
  "difficulty": "intermediate",
  "prerequisites": ["Linear Algebra (MATH 51)", "Probability & Statistics (CS109)", "Multivariable Calculus", "CS106A or CS106B (Programming)", "Python/NumPy"],
  "description": "Broad introduction to machine learning. Supervised learning, unsupervised learning, reinforcement learning, and learning theory with mathematical foundations.",
  "url": "https://cs229.stanford.edu/",
  "modules": [
    {
      "id": "mod-01",
      "week": 1,
      "title": "Supervised Learning Foundations",
      "description": "Linear regression, logistic regression, and generalized linear models.",
      "topics": [
        {
          "id": "topic-01-01",
          "title": "Linear Models and Optimization",
          "papers": [
            {
              "id": "paper-cs229-001",
              "title": "Regression Shrinkage and Selection Via the Lasso",
              "authors": ["Robert Tibshirani"],
              "year": 1996,
              "venue": "Journal of the Royal Statistical Society",
              "arxiv_id": null,
              "doi": "10.1111/j.2517-6161.1996.tb02080.x",
              "category": "required",
              "context": "L1 정규화(Lasso)를 제안. 희소 모델 선택과 정규화의 기초가 되었다."
            },
            {
              "id": "paper-cs229-002",
              "title": "Regularization and Variable Selection Via the Elastic Net",
              "authors": ["Hui Zou", "Trevor Hastie"],
              "year": 2005,
              "venue": "Journal of the Royal Statistical Society",
              "arxiv_id": null,
              "doi": "10.1111/j.1467-9868.2005.00503.x",
              "category": "optional",
              "context": "Elastic Net: L1과 L2 정규화를 결합하여 Lasso의 한계를 보완한 방법."
            }
          ]
        }
      ]
    },
    {
      "id": "mod-02",
      "week": 2,
      "title": "Support Vector Machines and Kernels",
      "description": "Maximum margin classifiers, kernel methods, and the kernel trick.",
      "topics": [
        {
          "id": "topic-02-01",
          "title": "SVM Theory",
          "papers": [
            {
              "id": "paper-cs229-003",
              "title": "A Training Algorithm for Optimal Margin Classifiers",
              "authors": ["Bernhard E. Boser", "Isabelle M. Guyon", "Vladimir N. Vapnik"],
              "year": 1992,
              "venue": "COLT",
              "arxiv_id": null,
              "doi": "10.1145/130385.130401",
              "category": "required",
              "context": "커널 트릭을 사용한 최대 마진 분류기(SVM)를 제안한 원조 논문."
            },
            {
              "id": "paper-cs229-004",
              "title": "Support-Vector Networks",
              "authors": ["Corinna Cortes", "Vladimir Vapnik"],
              "year": 1995,
              "venue": "Machine Learning",
              "arxiv_id": null,
              "doi": "10.1007/BF00994018",
              "category": "required",
              "context": "소프트 마진 SVM을 제안. 노이즈가 있는 데이터에서도 강건한 분류가 가능하게 했다."
            }
          ]
        }
      ]
    },
    {
      "id": "mod-03",
      "week": 3,
      "title": "Decision Trees and Ensemble Methods",
      "description": "Tree-based methods, random forests, and gradient boosting.",
      "topics": [
        {
          "id": "topic-03-01",
          "title": "Ensemble Learning",
          "papers": [
            {
              "id": "paper-cs229-005",
              "title": "Random Forests",
              "authors": ["Leo Breiman"],
              "year": 2001,
              "venue": "Machine Learning",
              "arxiv_id": null,
              "doi": "10.1023/A:1010933404324",
              "category": "required",
              "context": "랜덤 포레스트를 제안. 배깅과 특성 랜덤 선택으로 강력한 앙상블 모델을 구축한다."
            },
            {
              "id": "paper-cs229-006",
              "title": "XGBoost: A Scalable Tree Boosting System",
              "authors": ["Tianqi Chen", "Carlos Guestrin"],
              "year": 2016,
              "venue": "KDD",
              "arxiv_id": "1603.02754",
              "doi": "10.1145/2939672.2939785",
              "category": "required",
              "context": "XGBoost: 대규모 데이터에서 효율적인 그래디언트 부스팅. Kaggle 대회를 지배한 알고리즘."
            },
            {
              "id": "paper-cs229-007",
              "title": "Greedy Function Approximation: A Gradient Boosting Machine",
              "authors": ["Jerome H. Friedman"],
              "year": 2001,
              "venue": "Annals of Statistics",
              "arxiv_id": null,
              "doi": "10.1214/aos/1013203451",
              "category": "optional",
              "context": "그래디언트 부스팅의 이론적 프레임워크를 정립한 논문."
            }
          ]
        }
      ]
    },
    {
      "id": "mod-04",
      "week": 4,
      "title": "Unsupervised Learning",
      "description": "Clustering, dimensionality reduction, and density estimation.",
      "topics": [
        {
          "id": "topic-04-01",
          "title": "Clustering",
          "papers": [
            {
              "id": "paper-cs229-008",
              "title": "A Tutorial on Spectral Clustering",
              "authors": ["Ulrike von Luxburg"],
              "year": 2007,
              "venue": "Statistics and Computing",
              "arxiv_id": "0711.0189",
              "doi": "10.1007/s11222-007-9033-z",
              "category": "required",
              "context": "스펙트럴 클러스터링의 이론과 실제를 체계적으로 정리한 튜토리얼 논문."
            },
            {
              "id": "paper-cs229-017",
              "title": "Maximum Likelihood from Incomplete Data Via the EM Algorithm",
              "authors": ["Arthur P. Dempster", "Nan M. Laird", "Donald B. Rubin"],
              "year": 1977,
              "venue": "Journal of the Royal Statistical Society: Series B",
              "arxiv_id": null,
              "doi": "10.1111/j.2517-6161.1977.tb01600.x",
              "category": "required",
              "context": "불완전한 데이터에서 최대우도 추정을 위한 EM 알고리즘을 제안한 통계학 고전 논문"
            }
          ]
        },
        {
          "id": "topic-04-02",
          "title": "Dimensionality Reduction",
          "papers": [
            {
              "id": "paper-cs229-009",
              "title": "Visualizing Data using t-SNE",
              "authors": ["Laurens van der Maaten", "Geoffrey Hinton"],
              "year": 2008,
              "venue": "JMLR",
              "arxiv_id": null,
              "doi": null,
              "category": "required",
              "context": "t-SNE: 고차원 데이터의 시각화를 위한 비선형 차원 축소 방법."
            },
            {
              "id": "paper-cs229-010",
              "title": "UMAP: Uniform Manifold Approximation and Projection for Dimension Reduction",
              "authors": ["Leland McInnes", "John Healy", "James Melville"],
              "year": 2018,
              "venue": "arXiv",
              "arxiv_id": "1802.03426",
              "doi": null,
              "category": "optional",
              "context": "UMAP: t-SNE보다 빠르고 전역 구조를 더 잘 보존하는 차원 축소 방법."
            }
          ]
        }
      ]
    },
    {
