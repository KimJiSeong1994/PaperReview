              "category": "required",
              "context": "Region Proposal Network을 도입하여 객체 검출을 end-to-end로 학습 가능하게 만들었다."
            },
            {
              "id": "paper-cs231n-010",
              "title": "You Only Look Once: Unified, Real-Time Object Detection",
              "authors": ["Joseph Redmon", "Santosh Divvala", "Ross Girshick", "Ali Farhadi"],
              "year": 2016,
              "venue": "CVPR",
              "arxiv_id": "1506.02640",
