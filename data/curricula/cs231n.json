{
  "id": "cs231n",
  "name": "CS231N: Deep Learning for Computer Vision",
  "university": "Stanford University",
  "instructor": "Fei-Fei Li",
  "difficulty": "advanced",
  "prerequisites": ["Calculus & Linear Algebra", "CS109 (Probability & Statistics)", "CS106B (Programming Abstractions)", "CS229 or equivalent ML course", "Python/NumPy"],
  "description": "Convolutional neural networks and their applications in computer vision. Image classification, object detection, segmentation, generative models, and visual understanding.",
  "url": "https://cs231n.stanford.edu/",
  "modules": [
    {
      "id": "mod-01",
      "week": 1,
      "title": "Image Classification and Linear Classifiers",
      "description": "Fundamentals of image classification. K-Nearest Neighbors, linear classifiers, and loss functions.",
      "topics": [
        {
          "id": "topic-01-01",
          "title": "Image Classification Pipeline",
          "papers": [
            {
              "id": "paper-cs231n-001",
              "title": "ImageNet Large Scale Visual Recognition Challenge",
              "authors": ["Olga Russakovsky", "Jia Deng", "Hao Su", "Jonathan Krause", "Sanjeev Satheesh", "Sean Ma", "Zhiheng Huang", "Andrej Karpathy", "Aditya Khosla", "Michael Bernstein", "Alexander C. Berg", "Li Fei-Fei"],
              "year": 2015,
              "venue": "IJCV",
              "arxiv_id": "1409.0575",
              "doi": "10.1007/s11263-015-0816-y",
              "category": "required",
              "context": "ImageNet 챌린지의 역사와 데이터셋을 정리. 딥러닝 컴퓨터 비전 혁명의 촉매가 되었다."
            }
          ]
        }
      ]
    },
    {
      "id": "mod-02",
      "week": 2,
      "title": "Convolutional Neural Networks",
      "description": "CNN architecture design. Convolution, pooling, normalization layers.",
      "topics": [
        {
          "id": "topic-02-01",
          "title": "Classic CNN Architectures",
          "papers": [
            {
              "id": "paper-cs231n-002",
              "title": "ImageNet Classification with Deep Convolutional Neural Networks",
              "authors": ["Alex Krizhevsky", "Ilya Sutskever", "Geoffrey E. Hinton"],
              "year": 2012,
              "venue": "NeurIPS",
              "arxiv_id": null,
              "doi": "10.1145/3065386",
              "category": "required",
              "context": "AlexNet: 딥 CNN으로 ImageNet 대회에서 압도적 성능을 달성. 딥러닝 부흥의 시작."
            },
            {
              "id": "paper-cs231n-003",
              "title": "Very Deep Convolutional Networks for Large-Scale Image Recognition",
              "authors": ["Karen Simonyan", "Andrew Zisserman"],
              "year": 2015,
              "venue": "ICLR",
              "arxiv_id": "1409.1556",
              "doi": null,
              "category": "required",
              "context": "VGGNet: 3x3 작은 필터를 깊게 쌓는 것이 효과적임을 보여준 아키텍처."
            },
            {
              "id": "paper-cs231n-004",
              "title": "Going Deeper with Convolutions",
              "authors": ["Christian Szegedy", "Wei Liu", "Yangqing Jia", "Pierre Sermanet", "Scott Reed", "Dragomir Anguelov", "Dumitru Erhan", "Vincent Vanhoucke", "Andrew Rabinovich"],
              "year": 2015,
              "venue": "CVPR",
              "arxiv_id": "1409.4842",
              "doi": "10.1109/CVPR.2015.7298594",
              "category": "optional",
              "context": "GoogLeNet/Inception: 다양한 크기의 필터를 병렬로 사용하는 Inception 모듈을 제안."
            }
          ]
        },
        {
          "id": "topic-02-02",
          "title": "Residual Networks",
          "papers": [
            {
              "id": "paper-cs231n-005",
              "title": "Deep Residual Learning for Image Recognition",
              "authors": ["Kaiming He", "Xiangyu Zhang", "Shaoqing Ren", "Jian Sun"],
              "year": 2016,
              "venue": "CVPR",
              "arxiv_id": "1512.03385",
              "doi": "10.1109/CVPR.2016.90",
              "category": "required",
              "context": "ResNet: 잔차 연결(skip connection)로 매우 깊은 네트워크 학습을 가능하게 한 획기적 논문."
            },
            {
              "id": "paper-cs231n-006",
              "title": "Batch Normalization: Accelerating Deep Network Training by Reducing Internal Covariate Shift",
              "authors": ["Sergey Ioffe", "Christian Szegedy"],
              "year": 2015,
              "venue": "ICML",
              "arxiv_id": "1502.03167",
              "doi": null,
              "category": "required",
              "context": "배치 정규화를 제안. 딥 네트워크 학습의 안정성과 속도를 크게 개선했다."
            }
          ]
        }
      ]
    },
    {
